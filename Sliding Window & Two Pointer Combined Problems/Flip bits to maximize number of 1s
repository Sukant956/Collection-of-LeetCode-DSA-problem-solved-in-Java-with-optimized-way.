// Problem: Flip bits to maximize number of 1s
// Platform: LeetCode
// Approach:
// Time Complexity:
// Space Comlexity:

// Code

class Solution{
  public int maxOnes(int []arr){
    int totalOnes = 0;
    for(int x : arr){
      if(x == 1){
        totalOnes++;
      }
    }
    int maxGain = 0;
    int current = 0;
    for(int x : arr){
       if(x == 0){
          current += 1;
       }
      else{
         current -= 1;
      }
      if(current < 0){
         current = 0;
      }
      if(current > maxGain){
         maxGain = current;
      }
    }
   return totalOnes + maxGain;
  }
}
