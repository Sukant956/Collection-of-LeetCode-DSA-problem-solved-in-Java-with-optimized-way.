// Problem:Longest Alternating subsequence
// Platform: GFG
// Approach:
// Time Complexity: O(n)
// Space Complexity: O(n)

// Code

class Solution{
   public int alternatingMaxLength(int []arr){
      int inc = 1;
      int dec = 1;
      int n = arr.length;

      for(int i =1;i < n;i++){
         if(arr[i] > arr[i -1]){
            inc = dec + 1;
         }
         else if(arr[i] < arr[i - 1]){
            dec = inc + 1;
         }
      }
      return inc > dec ? inc : dec;
   }
}
