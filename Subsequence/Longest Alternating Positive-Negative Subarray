// Problem: Longest Alternating Positive-Negative Subarray
// Platform: LeetCode
// Approach: For Loop
// Time Complexity: O(n)
// Space Complexity: O(n)

// Code

class Solution {
    public int longestAlternatingPositiveNegativeSubarray(int nums[]) {

        if (nums.length == 0) return 0;

        int maxLength = 1;
        int currLength = 1;

        for (int i = 1; i < nums.length; i++) {

            if ((nums[i] > 0 && nums[i - 1] < 0) ||
                (nums[i] < 0 && nums[i - 1] > 0)) {

                currLength++;
            } else {
                currLength = 1;
            }

            maxLength = Math.max(maxLength, currLength);
        }

        return maxLength;
    }
}
